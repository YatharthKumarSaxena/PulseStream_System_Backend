{
  "name": "pulsestream-backend",
  "version": "1.0.0",
  "description": "Real-time health monitoring backend with Express and Socket.IO",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test-integration.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "redis": "^4.6.5",
    "dotenv": "^16.0.3",
    "module-alias": "^2.2.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  },
  "_moduleAliases": {
    "@configs": "src/configs",
    "@utils": "src/utils",
    "@services": "src/services",
